<?xml version="1.0" encoding="UTF-8"?>
<!-- Tizen TV web-app manifest. RetroSamsung is a Samsung Smart TV (Tizen) port
     of the RetroTv/RetroTube web app: the guide (index.html) and the flat/3D
     player (engine/viewer.html) run in the TV's Chromium runtime, driven by the
     remote (see tv.js and the handler in engine/viewer.html). -->
<widget xmlns="http://www.w3.org/ns/widgets"
        xmlns:tizen="http://tizen.org/ns/widgets"
        id="http://retrosamsung/retrotube"
        version="0.1.0" viewmodes="maximized">
  <tizen:application id="RtroSmsng1.RetroTube" package="RtroSmsng1" required_version="6.0"/>
  <name>RetroTube</name>
  <author>RetroSamsung</author>
  <description>Retro TV — classic shows streaming from archive.org, flat or on a 3D CRT.</description>
  <icon src="icon.png"/>
  <content src="index.html"/>
  <tizen:profile name="tv"/>

  <!-- 1080p landscape TV -->
  <feature name="http://tizen.org/feature/screen.size.normal.1080.1920"/>

  <!-- streams + metadata from archive.org, three.js/font from CDNs -->
  <access origin="*" subdomains="true"/>
  <tizen:privilege name="http://tizen.org/privilege/internet"/>
  <tizen:privilege name="http://tizen.org/privilege/tv.inputdevice"/>

  <tizen:setting screen-orientation="landscape" context-menu="disable"
                 background-support="disable" encryption="disable"
                 install-location="auto" hwkey-event="enable"/>
</widget>
